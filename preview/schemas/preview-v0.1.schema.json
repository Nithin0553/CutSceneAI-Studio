{
  "$defs": {
    "Axis": {
      "enum": [
        "x",
        "y",
        "z",
        "-x",
        "-y",
        "-z"
      ],
      "title": "Axis",
      "type": "string"
    },
    "CameraAngle": {
      "enum": [
        "eye_level",
        "low",
        "high",
        "dutch",
        "overhead"
      ],
      "title": "CameraAngle",
      "type": "string"
    },
    "CameraCut": {
      "additionalProperties": false,
      "properties": {
        "angle": {
          "$ref": "#/$defs/CameraAngle"
        },
        "beat_ids": {
          "items": {
            "type": "string"
          },
          "title": "Beat Ids",
          "type": "array"
        },
        "composition": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Composition"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "end_frame": {
          "exclusiveMinimum": 0,
          "title": "End Frame",
          "type": "integer"
        },
        "framing": {
          "$ref": "#/$defs/CameraFraming"
        },
        "lens_mm": {
          "maximum": 300,
          "minimum": 8,
          "title": "Lens Mm",
          "type": "number"
        },
        "movement": {
          "$ref": "#/$defs/CameraMovement"
        },
        "purpose": {
          "$ref": "#/$defs/ShotPurpose"
        },
        "shot_id": {
          "title": "Shot Id",
          "type": "string"
        },
        "start_frame": {
          "minimum": 0,
          "title": "Start Frame",
          "type": "integer"
        },
        "subject_ids": {
          "items": {
            "type": "string"
          },
          "title": "Subject Ids",
          "type": "array"
        },
        "target_ids": {
          "items": {
            "type": "string"
          },
          "title": "Target Ids",
          "type": "array"
        },
        "transform": {
          "anyOf": [
            {
              "$ref": "#/$defs/Transform"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "shot_id",
        "beat_ids",
        "start_frame",
        "end_frame",
        "purpose",
        "description",
        "subject_ids",
        "framing",
        "angle",
        "movement",
        "lens_mm",
        "target_ids"
      ],
      "title": "CameraCut",
      "type": "object"
    },
    "CameraFraming": {
      "enum": [
        "extreme_wide",
        "wide",
        "medium_wide",
        "medium",
        "medium_close_up",
        "close_up",
        "extreme_close_up",
        "over_the_shoulder",
        "point_of_view",
        "insert"
      ],
      "title": "CameraFraming",
      "type": "string"
    },
    "CameraMovement": {
      "enum": [
        "static",
        "pan",
        "tilt",
        "dolly",
        "truck",
        "crane",
        "handheld",
        "orbit"
      ],
      "title": "CameraMovement",
      "type": "string"
    },
    "EntityKind": {
      "enum": [
        "character",
        "environment"
      ],
      "title": "EntityKind",
      "type": "string"
    },
    "Handedness": {
      "enum": [
        "left",
        "right"
      ],
      "title": "Handedness",
      "type": "string"
    },
    "PerformanceCue": {
      "additionalProperties": false,
      "properties": {
        "beat_id": {
          "title": "Beat Id",
          "type": "string"
        },
        "character_id": {
          "title": "Character Id",
          "type": "string"
        },
        "dialogue": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dialogue"
        },
        "dialogue_start_frame": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dialogue Start Frame"
        },
        "emotion": {
          "title": "Emotion",
          "type": "string"
        },
        "emotion_intensity": {
          "maximum": 1,
          "minimum": 0,
          "title": "Emotion Intensity",
          "type": "number"
        },
        "end_frame": {
          "exclusiveMinimum": 0,
          "title": "End Frame",
          "type": "integer"
        },
        "lip_sync": {
          "title": "Lip Sync",
          "type": "boolean"
        },
        "look_at_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Look At Id"
        },
        "motion_prompt": {
          "title": "Motion Prompt",
          "type": "string"
        },
        "motion_style": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Motion Style"
        },
        "start_frame": {
          "minimum": 0,
          "title": "Start Frame",
          "type": "integer"
        }
      },
      "required": [
        "beat_id",
        "start_frame",
        "end_frame",
        "character_id",
        "motion_prompt",
        "emotion",
        "emotion_intensity",
        "lip_sync"
      ],
      "title": "PerformanceCue",
      "type": "object"
    },
    "PlaceholderShape": {
      "enum": [
        "capsule",
        "box"
      ],
      "title": "PlaceholderShape",
      "type": "string"
    },
    "PreviewEntity": {
      "additionalProperties": false,
      "properties": {
        "asset_uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asset Uri"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "initial_transform": {
          "$ref": "#/$defs/Transform"
        },
        "kind": {
          "$ref": "#/$defs/EntityKind"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "placeholder_color": {
          "pattern": "^#[0-9A-F]{6}$",
          "title": "Placeholder Color",
          "type": "string"
        },
        "placeholder_shape": {
          "$ref": "#/$defs/PlaceholderShape"
        }
      },
      "required": [
        "id",
        "name",
        "kind",
        "placeholder_shape",
        "placeholder_color",
        "initial_transform"
      ],
      "title": "PreviewEntity",
      "type": "object"
    },
    "PreviewScene": {
      "additionalProperties": false,
      "properties": {
        "camera_cuts": {
          "items": {
            "$ref": "#/$defs/CameraCut"
          },
          "title": "Camera Cuts",
          "type": "array"
        },
        "duration_frames": {
          "exclusiveMinimum": 0,
          "title": "Duration Frames",
          "type": "integer"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "location": {
          "title": "Location",
          "type": "string"
        },
        "performance_cues": {
          "items": {
            "$ref": "#/$defs/PerformanceCue"
          },
          "title": "Performance Cues",
          "type": "array"
        },
        "title": {
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "location",
        "duration_frames",
        "performance_cues",
        "camera_cuts"
      ],
      "title": "PreviewScene",
      "type": "object"
    },
    "PreviewWarning": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "entity_id": {
          "title": "Entity Id",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "entity_id",
        "message"
      ],
      "title": "PreviewWarning",
      "type": "object"
    },
    "ProjectSettings": {
      "additionalProperties": false,
      "properties": {
        "distance_unit": {
          "const": "meter",
          "default": "meter",
          "title": "Distance Unit",
          "type": "string"
        },
        "forward_axis": {
          "$ref": "#/$defs/Axis",
          "default": "-z"
        },
        "fps": {
          "default": 24,
          "maximum": 240,
          "minimum": 1,
          "title": "Fps",
          "type": "integer"
        },
        "handedness": {
          "$ref": "#/$defs/Handedness",
          "default": "right"
        },
        "time_unit": {
          "const": "second",
          "default": "second",
          "title": "Time Unit",
          "type": "string"
        },
        "up_axis": {
          "$ref": "#/$defs/Axis",
          "default": "y"
        }
      },
      "title": "ProjectSettings",
      "type": "object"
    },
    "Quaternion": {
      "additionalProperties": false,
      "properties": {
        "w": {
          "default": 1.0,
          "title": "W",
          "type": "number"
        },
        "x": {
          "default": 0.0,
          "title": "X",
          "type": "number"
        },
        "y": {
          "default": 0.0,
          "title": "Y",
          "type": "number"
        },
        "z": {
          "default": 0.0,
          "title": "Z",
          "type": "number"
        }
      },
      "title": "Quaternion",
      "type": "object"
    },
    "ShotPurpose": {
      "enum": [
        "establishing",
        "environment_detail",
        "dialogue",
        "reaction",
        "action",
        "transition"
      ],
      "title": "ShotPurpose",
      "type": "string"
    },
    "Transform": {
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "#/$defs/Vector3"
        },
        "rotation": {
          "$ref": "#/$defs/Quaternion"
        },
        "scale": {
          "$ref": "#/$defs/Vector3"
        }
      },
      "title": "Transform",
      "type": "object"
    },
    "Vector3": {
      "additionalProperties": false,
      "properties": {
        "x": {
          "default": 0.0,
          "title": "X",
          "type": "number"
        },
        "y": {
          "default": 0.0,
          "title": "Y",
          "type": "number"
        },
        "z": {
          "default": 0.0,
          "title": "Z",
          "type": "number"
        }
      },
      "title": "Vector3",
      "type": "object"
    }
  },
  "$id": "https://schemas.cutsceneai.dev/preview/v0.1/manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "cir_schema_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Cir Schema Version",
      "type": "string"
    },
    "entities": {
      "items": {
        "$ref": "#/$defs/PreviewEntity"
      },
      "title": "Entities",
      "type": "array"
    },
    "preview_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Preview Version",
      "type": "string"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "project_name": {
      "title": "Project Name",
      "type": "string"
    },
    "scenes": {
      "items": {
        "$ref": "#/$defs/PreviewScene"
      },
      "title": "Scenes",
      "type": "array"
    },
    "settings": {
      "$ref": "#/$defs/ProjectSettings"
    },
    "warnings": {
      "items": {
        "$ref": "#/$defs/PreviewWarning"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "project_id",
    "project_name",
    "settings",
    "entities",
    "scenes",
    "warnings"
  ],
  "title": "PreviewManifest",
  "type": "object"
}
